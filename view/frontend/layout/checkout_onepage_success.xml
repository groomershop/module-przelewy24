<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="order.success.additional.info">
            <block name="checkout.przelewy24.payment.status" ifconfig="payment/przelewy24/wait_for_transaction_result" template="PayPro_Przelewy24::checkout/payment/status.phtml" cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">PayPro\Przelewy24\ViewModel\Checkout\PaymentStatus</argument>
                </arguments>
            </block>
            <block name="checkout.przelewy24.payment.link" template="PayPro_Przelewy24::checkout/payment/link.phtml" cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">PayPro\Przelewy24\ViewModel\Checkout\PaymentLink</argument>
                </arguments>
            </block>
            <block name="checkout.przelewy24.payment.blik" template="PayPro_Przelewy24::checkout/payment/blik.phtml" cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">PayPro\Przelewy24\ViewModel\Checkout\BlikViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
