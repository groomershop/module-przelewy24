<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="sales_order_tabs">
            <action method="addTab">
                <argument name="name" xsi:type="string">order_p24_refunds</argument>
                <argument name="block" xsi:type="string">PayPro\Przelewy24\Block\Adminhtml\Order\View\Tab\RefundTab</argument>
            </action>
        </referenceBlock>
        <referenceContainer name="content">
            <block name="przelewy24_placement" ifconfig="payment/przelewy24/active" template="PayPro_Przelewy24::order/view/placement.phtml" before="sales_order_edit">
                <arguments>
                    <argument name="view_model" xsi:type="object">PayPro\Przelewy24\ViewModel\PlacementViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
