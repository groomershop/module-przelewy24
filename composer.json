{
    "name": "groomershop/module-przelewy24",
    "description": "Przelewy24 payment module for Magento 2 (by GroomerShop)",
    "version": "1.5.0",
    "keywords": [
        "przelewy24",
        "paypro",
        "payment",
        "magento"
    ],
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "magento/composer-dependency-version-audit-plugin": true
        }
    },
    "type": "magento2-module",
    "license": "LGPL-3.0-only",
    "require": {
        "ext-json": "*",
        "magento/module-payment": "100.3.*||^100.4.0",
        "magento/module-vault": "^101.2.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "bitexpert/phpstan-magento": "^0.19.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.1",
        "magento/magento-coding-standard": "*",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpmd/phpmd": "^2.9.1",
        "phpstan/phpstan": "~1.5.0",
        "phpunit/phpunit": "~9.5.0",
        "slevomat/coding-standard": "~6.4.1",
        "squizlabs/php_codesniffer": "~3.6.0",
        "phpstan/phpstan-phpunit": "^1.1.1",
        "laminas/laminas-code": "4.5.0 as 3.5.1"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.magento.com/"
        }
    ],
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "PayPro\\Przelewy24\\": ""
        }
    }
}
